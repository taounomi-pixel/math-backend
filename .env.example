# Supabase Database URL
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# Supabase Auth & Storage (Found in Settings -> API)
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=ey...  # Use SERVICE ROLE KEY for backend storage upload
SUPABASE_BUCKET_NAME=videos

# Session Secret Key
SECRET_KEY=your-secure-random-key-here

# SMTP (QQ Mail) — for Email OTP
SMTP_EMAIL=your-qq-email@qq.com
SMTP_PASSWORD=your-smtp-authorization-code
